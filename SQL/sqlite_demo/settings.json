// VS Code 的 settings.json 檔案
{
    // ... 您的其他 VS Code 設定 ...

    "sqltools.connections": [
        {
            // 連線到 SQLite 資料庫的正確設定
            "name": "HachiTsai SQLite", // 您可以自訂顯示名稱
            "driver": "SQLite",         // 驅動程式必須是 "SQLite"
            "database": "${workspaceFolder}/demo.sqlite", // SQLite 資料庫檔案的路徑
            "previewLimit": 50
        }
        // 如果有多個連線，可以在這裡繼續新增
        // {
        //     "name": "另一個資料庫連線",
        //     "driver": "MySQL",
        //     "server": "192.168.1.100",
        //     "port": 3306,
        //     "user": "root",
        //     "database": "my_app"
        // }
    ]

    // ... 您的其他 VS Code 設定 ...
}
