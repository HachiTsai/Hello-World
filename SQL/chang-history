    "sqltools.connections": [
        {
            // 連線設定的範例 (以 PostgreSQL 為例)
            "name": "HachiTsa", // 在 SQLTools 側邊欄中顯示的名稱，可自訂
            "driver": "MySQL",     // 資料庫類型，需要安裝對應的驅動程式擴充套件
            "previewLimit": 50,         // 查詢結果預覽的行數限制
            "server": "localhost",      // 資料庫主機位址 (或 IP)
            "port": 5432,               // 資料庫監聽的連接埠
            "user": "HachiTsai",
            "database": "demo.sqlite"
            // "password": "您的密碼" // 為了安全，建議不要直接儲存密碼。
                                    // 您可以將此行刪除或註解掉，
                                    // SQLTools 會在每次連線時提示您輸入密碼。
            // 連線到 SQLite 資料庫的正確設定
            "name": "HachiTsai SQLite", // 您可以自訂顯示名稱
            "driver": "SQLite",         // 驅動程式必須是 "SQLite"
            "database": "${workspaceFolder}/demo.sqlite", // SQLite 資料庫檔案的路徑
            "previewLimit": 50
        }
        // 如果有多個連線，可以在這裡繼續新增
