{
    "cSpell.words": [
        "oneshot"
    ],
    "cSpell.customDictionaries": {
        "custom-dictionary-workspace": {
            "name": "custom-dictionary-workspace",
            "path": "${workspaceFolder:Hello-World}/.cspell/custom-dictionary-workspace.txt",
            "addWords": true,
            "scope": "workspace"
        }
    },
    "sqltools.connections": [
        {
            "name": "HachiTsai SQLite",
            "driver": "SQLite",
            "database": "SQL/demo.sqlite",
            "previewLimit": 50
        }
    ],
    "sqltools.useNodeRuntime": true
}
